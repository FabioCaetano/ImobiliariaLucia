# Supabase project URL and public anonymous key (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Server-only key. Never prefix this value with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Comma-separated Supabase Auth users allowed to access /admin.
ADMIN_EMAILS=lucia@imobiliariadalucia.ca
